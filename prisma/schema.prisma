// Simple POS - Prisma Schema
// Auth.js models + POS models untuk PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js Required Models ───────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hash bcrypt, nullable karena auth provider lain
  role          String    @default("kasir") // "admin" | "kasir"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  orders   Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── POS Models ────────────────────────────────────────────

model MenuItem {
  id        String   @id @default(cuid())
  name      String
  price     Int      // dalam rupiah (ex: 25000 = Rp25.000)
  category  String   // "makanan" | "minuman" | "snack"
  image     String?  // URL gambar (opsional)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  cashierId     String
  cashier       User        @relation(fields: [cashierId], references: [id])
  items         OrderItem[]
  total         Int         // total dalam rupiah
  paymentAmount Int         // jumlah bayar
  change        Int         // kembalian
  createdAt     DateTime    @default(now())

  @@map("orders")
}

model OrderItem {
  id       String   @id @default(cuid())
  orderId  String
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuId   String
  menu     MenuItem @relation(fields: [menuId], references: [id])
  name     String   // snapshot nama item saat transaksi
  quantity Int
  price    Int      // snapshot harga per item saat transaksi

  @@map("order_items")
}
